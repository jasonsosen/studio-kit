{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-app-read-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/.studio-kit/**"
      ]
    }
  ]
}
